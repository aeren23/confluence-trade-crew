# ══════════════════════════════════════════════════════════════════════════
# LLM Provider Configuration — Strategy Pattern
# ══════════════════════════════════════════════════════════════════════════
# Switch providers by changing LLM_DEFAULT_PROVIDER + LLM_DEFAULT_MODEL.
# No code changes needed. Per-agent overrides are optional.
#
# ── Provider Quick-Switch Reference ─────────────────────────────────────
#
# Anthropic (default):
#   LLM_DEFAULT_PROVIDER=anthropic
#   LLM_DEFAULT_MODEL=claude-sonnet-4-20250514
#   ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI:
#   LLM_DEFAULT_PROVIDER=openai
#   LLM_DEFAULT_MODEL=gpt-4o
#   OPENAI_API_KEY=sk-...
#
# Google Gemini:
#   LLM_DEFAULT_PROVIDER=gemini
#   LLM_DEFAULT_MODEL=gemini-2.0-flash
#   GEMINI_API_KEY=AI...
#
# GitHub Models (distributed — recommended for free/student tier):
#   IMPORTANT: Only gpt-4.1 family models work reliably with CrewAI+litellm.
#   Non-OpenAI models (Mistral, Llama) trigger an async code path in litellm
#   that returns None inside CrewAI's thread-pool executor.
#   Distribute across nano/mini/full to spread the 150 req/day per-model limit.
#   With 8 agents (Faz 1), recommended distribution (750 req/day total):
#   LLM_DEFAULT_PROVIDER=github
#   LLM_DEFAULT_MODEL=gpt-4.1-nano
#   LLM_DATA_AGENT_MODEL=github/gpt-4.1-nano              # 150/day — simple fetch+report
#   LLM_MARKET_STRUCTURE_AGENT_MODEL=github/gpt-4.1-nano  # 150/day — tool-heavy, light LLM
#   LLM_TA_AGENT_MODEL=github/gpt-4.1-mini               # 150/day — indicator interpretation
#   LLM_NEWS_AGENT_MODEL=github/gpt-4.1-nano             # shared pool with Data
#   LLM_RISK_AGENT_MODEL=github/gpt-4.1-mini             # shared pool with TA
#   LLM_ONCHAIN_AGENT_MODEL=github/gpt-4.1-nano          # shared pool
#   LLM_ORCHESTRATOR_MODEL=github/gpt-4.1                # 150/day — synthesis needs best model
#   GITHUB_API_KEY=<PAT with models:read scope>
#
# Ollama (local — no API key required):
#   LLM_DEFAULT_PROVIDER=ollama
#   LLM_DEFAULT_MODEL=llama3
# ─────────────────────────────────────────────────────────────────────────

LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514

# Per-agent model overrides (optional — leave empty to use defaults above)
# Format: "provider/model"  e.g. "openai/gpt-4o", "gemini/gemini-2.0-flash"
# Tip (GitHub Models): assign a different model per agent to distribute
# daily quotas — each Low-tier model allows 150 req/day independently.
# LLM_DATA_AGENT_MODEL=
# LLM_MARKET_STRUCTURE_AGENT_MODEL=   # Faz 1: lightweight price action analysis
# LLM_TA_AGENT_MODEL=
# LLM_NEWS_AGENT_MODEL=
# LLM_RISK_AGENT_MODEL=
# LLM_ORCHESTRATOR_MODEL=
# LLM_ONCHAIN_AGENT_MODEL=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Disable CrewAI cloud telemetry (uses OpenTelemetry standard env var)
# This suppresses ConnectionResetError spam when the telemetry endpoint is unreachable
CREWAI_TELEMETRY_ENABLED=false
OTEL_SDK_DISABLED=true

# ══════════════════════════════════════════════════════════════════════════
# API Keys
# ══════════════════════════════════════════════════════════════════════════

# Anthropic — required when LLM_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# OpenAI — required when LLM_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=

# GitHub Models — required when LLM_DEFAULT_PROVIDER=github
# Generate a fine-grained PAT at https://github.com/settings/tokens
# with "Models" → "Read-only" permission (models:read scope)
GITHUB_API_KEY=

# Google Gemini — required when LLM_DEFAULT_PROVIDER=gemini
# Generate at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ══════════════════════════════════════════════════════════════════════════
# Database
# ══════════════════════════════════════════════════════════════════════════
POSTGRES_USER=confluence
POSTGRES_PASSWORD=changeme
POSTGRES_DB=confluence

# ══════════════════════════════════════════════════════════════════════════
# Optional Keys
# ══════════════════════════════════════════════════════════════════════════

# Raises Binance rate limits (public endpoints work without it)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Enables pair-specific news via CryptoPanic
# If left empty, the News Agent falls back to web search only
CRYPTOPANIC_API_KEY=

# ══════════════════════════════════════════════════════════════════════════
# Port Overrides
# ══════════════════════════════════════════════════════════════════════════
API_PORT=5000
AI_SERVICE_PORT=8000
FRONTEND_PORT=3000
