# ── LLM Provider Configuration ──────────────────────────────────────────
# Default: Anthropic Claude. Change these 2 lines to switch all agents.
# No code changes needed — Strategy Pattern via environment variables.
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-20250514

# Per-agent model overrides (optional — leave empty to use defaults above)
# Format: "provider/model" e.g. "openai/gpt-4o", "ollama/llama3"
LLM_DATA_AGENT_MODEL=
LLM_TA_AGENT_MODEL=
LLM_NEWS_AGENT_MODEL=
LLM_RISK_AGENT_MODEL=
LLM_ORCHESTRATOR_MODEL=

# LLM parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Disable CrewAI cloud telemetry (uses OpenTelemetry standard env var)
# This suppresses ConnectionResetError spam when the telemetry endpoint is unreachable
CREWAI_TELEMETRY_ENABLED=false
OTEL_SDK_DISABLED=true

# ── API Keys ────────────────────────────────────────────────────────────
# Required for the default Anthropic provider
ANTHROPIC_API_KEY=

# Required if LLM_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=

# Required if LLM_DEFAULT_PROVIDER=github
GITHUB_API_KEY=

# ── Database ────────────────────────────────────────────────────────────
POSTGRES_USER=confluence
POSTGRES_PASSWORD=changeme
POSTGRES_DB=confluence

# ── Optional — raises Binance rate limits, not required for basic usage ─
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Optional — enables pair-specific news via CryptoPanic ──────────────
# If left empty, the News Agent falls back to web search only
CRYPTOPANIC_API_KEY=

# ── Optional — port overrides ───────────────────────────────────────────
API_PORT=5000
AI_SERVICE_PORT=8000
FRONTEND_PORT=3000
